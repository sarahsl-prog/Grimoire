# Grimoire Environment Configuration Template
# Copy this file to .env and fill in your values
# See docs/DESIGN.md Section 10 for detailed documentation
#
# Naming convention for Grimoire app settings:
#   GRIMOIRE_<SECTION>__<FIELD>=value   (double underscore = nesting)
#   Example: GRIMOIRE_LLM__MODEL=llama3.2
#
# Variables WITHOUT the GRIMOIRE_ prefix are for Docker Compose / external
# tooling (Postgres, PgAdmin, Redis Commander) — they are NOT read by the
# Python application.

# =============================================================================
# DATABASE — Docker Compose infrastructure vars (not read by Python app)
# =============================================================================
POSTGRES_USER=grimoire
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=grimoire
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full database URL read by the Grimoire app:
GRIMOIRE_DATABASE__URL=postgresql+asyncpg://grimoire:changeme@localhost:5432/grimoire
GRIMOIRE_DATABASE__ECHO=false
GRIMOIRE_DATABASE__POOL_SIZE=10

# =============================================================================
# REDIS — Grimoire app settings
# =============================================================================
GRIMOIRE_REDIS__HOST=localhost
GRIMOIRE_REDIS__PORT=6379
GRIMOIRE_REDIS__DB_CACHE=2
GRIMOIRE_REDIS__DB_RATE_LIMIT=3
GRIMOIRE_REDIS__PASSWORD=

# =============================================================================
# VECTOR STORE
# =============================================================================
GRIMOIRE_VECTOR_STORE__TYPE=chromadb
GRIMOIRE_VECTOR_STORE__CHROMADB__PATH=./chroma_db
GRIMOIRE_VECTOR_STORE__CHROMADB__COLLECTION_NAME=documents

# =============================================================================
# LLM (Ollama)
# =============================================================================
GRIMOIRE_LLM__URL=http://localhost:11434
GRIMOIRE_LLM__MODEL=llama3.2
GRIMOIRE_LLM__TEMPERATURE=0.7
GRIMOIRE_LLM__MAX_TOKENS=4096
GRIMOIRE_LLM__TIMEOUT=300
# Fallback — used if primary URL is unreachable (optional)
# GRIMOIRE_LLM__FALLBACK_URL=http://backup-host:11434
# GRIMOIRE_LLM__FALLBACK_MODEL=llama3.2

# =============================================================================
# EMBEDDINGS
# =============================================================================
GRIMOIRE_EMBEDDINGS__MODEL=sentence-transformers/all-mpnet-base-v2
GRIMOIRE_EMBEDDINGS__FALLBACK_MODEL=sentence-transformers/all-MiniLM-L6-v2
GRIMOIRE_EMBEDDINGS__DEVICE=auto
GRIMOIRE_EMBEDDINGS__BATCH_SIZE=32

# =============================================================================
# LOGGING
# =============================================================================
GRIMOIRE_LOGGING__LEVEL=INFO
GRIMOIRE_LOGGING__LOG_DIR=./logs
GRIMOIRE_LOGGING__ROTATION=1 week
GRIMOIRE_LOGGING__RETENTION=1 month
GRIMOIRE_LOGGING__STRUCTURED=true
GRIMOIRE_LOGGING__USE_JSON=false

# =============================================================================
# CELERY
# =============================================================================
GRIMOIRE_CELERY__BROKER_URL=redis://localhost:6379/0
GRIMOIRE_CELERY__RESULT_BACKEND=redis://localhost:6379/1
GRIMOIRE_CELERY__TASK_SERIALIZER=json
GRIMOIRE_CELERY__ACCEPT_CONTENT=["json"]
GRIMOIRE_CELERY__RESULT_SERIALIZER=json
GRIMOIRE_CELERY__TIMEZONE=UTC
GRIMOIRE_CELERY__ENABLE_UTC=true

# =============================================================================
# CHUNKING
# =============================================================================
GRIMOIRE_CHUNKING__DEFAULT_STRATEGY=semantic
GRIMOIRE_CHUNKING__CHUNK_SIZE=1000
GRIMOIRE_CHUNKING__CHUNK_OVERLAP=200
GRIMOIRE_CHUNKING__SEMANTIC__THRESHOLD=0.5
GRIMOIRE_CHUNKING__SEMANTIC__MIN_CHUNK_SIZE=100

# =============================================================================
# PROCESSING
# =============================================================================
GRIMOIRE_PROCESSING__PARSE_PDF_OCR=true
GRIMOIRE_PROCESSING__PARSE_IMAGES=true
GRIMOIRE_PROCESSING__AUTO_TAG_THRESHOLD=0.7
GRIMOIRE_PROCESSING__DEDUP_STRATEGY=hash
GRIMOIRE_PROCESSING__CONCURRENCY=4
GRIMOIRE_PROCESSING__RATE_LIMIT_CLOUD=true

# =============================================================================
# QUERY / RAG
# =============================================================================
GRIMOIRE_QUERY__DEFAULT_TOP_K=10
GRIMOIRE_QUERY__RERANK_TOP_K=50
GRIMOIRE_QUERY__RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
GRIMOIRE_QUERY__HYBRID_ALPHA=0.7
GRIMOIRE_QUERY__ENABLE_CITATIONS=true

# =============================================================================
# CACHE
# =============================================================================
GRIMOIRE_CACHE__STORAGE=disk
GRIMOIRE_CACHE__PATH=./cache
GRIMOIRE_CACHE__EMBEDDING_TTL=604800
GRIMOIRE_CACHE__RESULT_TTL=86400
GRIMOIRE_CACHE__GENERATION_TTL=2592000

# =============================================================================
# FILE WATCHING
# =============================================================================
GRIMOIRE_WATCH__DEFAULT_POLL_INTERVAL=300
GRIMOIRE_WATCH__MAX_LOCAL_WATCHES=100

# =============================================================================
# CLOUD STORAGE — Google Drive
# =============================================================================
GRIMOIRE_CLOUD__GOOGLE__CREDENTIALS_PATH=~/.config/gcloud/credentials.json
GRIMOIRE_CLOUD__GOOGLE__TOKEN_STORE=~/.config/grimoire/gdrive_tokens.json
GRIMOIRE_CLOUD__GOOGLE__CLIENT_ID=
GRIMOIRE_CLOUD__GOOGLE__CLIENT_SECRET=

# =============================================================================
# CLOUD STORAGE — OneDrive
# =============================================================================
GRIMOIRE_CLOUD__ONEDRIVE__CLIENT_ID=
GRIMOIRE_CLOUD__ONEDRIVE__CLIENT_SECRET=
GRIMOIRE_CLOUD__ONEDRIVE__TOKEN_STORE=~/.config/grimoire/onedrive_tokens.json

# =============================================================================
# OBSERVABILITY
# Read by GrimoireSettings:
GRIMOIRE_OBSERVABILITY__TRACING=false
GRIMOIRE_OBSERVABILITY__METRICS=false
# Read directly by OpenTelemetry SDK (not GrimoireSettings):
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=grimoire
# =============================================================================

# =============================================================================
# API
# =============================================================================
GRIMOIRE_API__HOST=0.0.0.0
GRIMOIRE_API__PORT=8001
GRIMOIRE_API__RELOAD=false
GRIMOIRE_API__WORKERS=4
GRIMOIRE_API__SECRET_KEY=your-secret-key-change-me-in-production

# =============================================================================
# AUTH & RATE LIMITING
# =============================================================================
GRIMOIRE_AUTH__CORS_ORIGINS=["*"]
GRIMOIRE_AUTH__RATE_LIMITS={"agt":"600/minute","dvl":"120/minute","rdl":"30/minute"}

# =============================================================================
# WIKI
# =============================================================================
GRIMOIRE_WIKI__COMPILE_ON_INGEST=false
# GRIMOIRE_WIKI__WIKI_PAGES_DIR=wiki/
# GRIMOIRE_WIKI__MAX_SECTIONS_PER_PAGE=10
# GRIMOIRE_WIKI__COMPILE_MODEL=                 # override model for wiki compilation

# =============================================================================
# TOP-LEVEL
# =============================================================================
GRIMOIRE_DEBUG=false

# =============================================================================
# DOCKER COMPOSE — dev tooling only (not read by Python app)
# =============================================================================
PGADMIN_EMAIL=admin@grimoire.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
REDIS_COMMANDER_PORT=8081
