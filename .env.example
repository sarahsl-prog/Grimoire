# Grimoire Environment Configuration Template
# Copy this file to .env and fill in your values
# See docs/DESIGN.md Section 10 for detailed documentation

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
POSTGRES_USER=grimoire
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=grimoire
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full database URL (optional - constructed from above if not set)
# DATABASE_URL=postgresql://grimoire:changeme@localhost:5432/grimoire

# =============================================================================
# REDIS CONFIGURATION (Cache & Message Broker)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB_CACHE=2
REDIS_PASSWORD=
# Full Redis URL (optional - constructed from above if not set)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CHROMADB CONFIGURATION (Vector Store)
# =============================================================================
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PATH=./chroma_db
CHROMADB_COLLECTION=documents
# Vector store type: chromadb | qdrant (qdrant for future migration)
VECTOR_STORE_TYPE=chromadb

# =============================================================================
# LLM CONFIGURATION (Ollama)
# =============================================================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4096
OLLAMA_TIMEOUT=300

# =============================================================================
# EMBEDDINGS CONFIGURATION
# =============================================================================
# Primary embedding model (default: all-mpnet-base-v2)
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_FALLBACK_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Device: auto | cuda | cpu | mps (Apple Silicon)
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=32

# =============================================================================
# LOGGING CONFIGURATION (loguru)
# =============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_DIR=./logs
LOG_ROTATION=1 week
LOG_RETENTION=1 month
LOG_STRUCTURED=true
LOG_JSON=false

# =============================================================================
# CELERY CONFIGURATION (Distributed Task Queue)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# =============================================================================
# CHUNKING CONFIGURATION
# =============================================================================
# Strategy: semantic | markdown | recursive
CHUNKING_DEFAULT_STRATEGY=semantic
CHUNKING_CHUNK_SIZE=1000
CHUNKING_CHUNK_OVERLAP=200
CHUNKING_SEMANTIC_THRESHOLD=0.5
CHUNKING_MIN_CHUNK_SIZE=100

# =============================================================================
# PROCESSING CONFIGURATION
# =============================================================================
PROCESSING_PARSE_PDF_OCR=true
PROCESSING_PARSE_IMAGES=true
PROCESSING_AUTO_TAG_THRESHOLD=0.7
PROCESSING_DEDUP_STRATEGY=hash
PROCESSING_CONCURRENCY=4
PROCESSING_RATE_LIMIT_CLOUD=true

# =============================================================================
# QUERY CONFIGURATION
# =============================================================================
QUERY_DEFAULT_TOP_K=10
QUERY_RERANK_TOP_K=50
QUERY_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
QUERY_HYBRID_ALPHA=0.7
QUERY_ENABLE_CITATIONS=true

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_STORAGE=disk
# Options: disk | redis
CACHE_PATH=./cache
CACHE_EMBEDDING_TTL=604800
CACHE_RESULT_TTL=86400
CACHE_GENERATION_TTL=2592000

# =============================================================================
# WATCH CONFIGURATION
# =============================================================================
WATCH_DEFAULT_POLL_INTERVAL=300
WATCH_MAX_LOCAL_WATCHES=100

# =============================================================================
# CLOUD STORAGE CONFIGURATION (Google Drive)
# =============================================================================
GOOGLE_CREDENTIALS_PATH=~/.config/gcloud/credentials.json
GOOGLE_TOKEN_STORE=~/.config/grimoire/gdrive_tokens.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# CLOUD STORAGE CONFIGURATION (OneDrive)
# =============================================================================
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TOKEN_STORE=~/.config/grimoire/onedrive_tokens.json

# =============================================================================
# OBSERVABILITY CONFIGURATION
# =============================================================================
# Enable OpenTelemetry/LangSmith tracing
OTEL_TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=grimoire
# Enable Prometheus metrics export
METRICS_ENABLED=false
METRICS_PORT=9090

# =============================================================================
# PGADMIN CONFIGURATION (Optional - for development)
# =============================================================================
PGADMIN_EMAIL=admin@grimoire.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# =============================================================================
# REDIS COMMANDER CONFIGURATION (Optional - for development)
# =============================================================================
REDIS_COMMANDER_PORT=8081

# =============================================================================
# API CONFIGURATION (FastAPI)
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=false
API_WORKERS=4
API_SECRET_KEY=your-secret-key-change-me-in-production

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Never commit the actual secret key to version control!
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to true for development mode
DEBUG=false
# Set to true to echo SQL statements
SQL_ECHO=false
# Database pool size (PostgreSQL only)
DB_POOL_SIZE=10
