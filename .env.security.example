# Grimoire Security-Mode Environment Configuration
#
# Copy to .env and edit before running:
#   cp .env.security.example .env
#   docker compose -f docker-compose.yml -f docker-compose.security.yml up -d
#
# This profile flips the strategy loader into the security domain
# (Sigma / NVD CVE / MITRE ATT&CK chunking + SecurityRetriever re-rank)
# and uses an isolated Postgres port + Chroma collection so it can run
# alongside an existing general-domain instance.
#
# See docs/deploy/hetzner_security.md for the full deploy guide and
# docs/strategies/configuration.md for the full settings reference.

# =============================================================================
# SECURITY DOMAIN SWITCH
# =============================================================================
# This is the only setting that turns the security pipeline on. Without it
# Grimoire behaves identically to a general-domain install.
GRIMOIRE_SECURITY__DOMAIN=security
# Off by default — the LLM extractor adds latency to ingest. Enable when
# ingesting prose threat-intel (blog posts, HTB notes, etc.).
GRIMOIRE_SECURITY__LLM_EXTRACT_ENABLED=false
# Recency half-life for the SecurityRetriever score decay (0 to disable).
GRIMOIRE_SECURITY__RECENCY_HALF_LIFE_DAYS=365

# =============================================================================
# DATABASE — isolated port so general + security can coexist on one host
# =============================================================================
POSTGRES_USER=grimoire
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=grimoire_security
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

GRIMOIRE_DATABASE__URL=postgresql+asyncpg://grimoire:changeme_secure_password@localhost:5433/grimoire_security
GRIMOIRE_DATABASE__ECHO=false
GRIMOIRE_DATABASE__POOL_SIZE=10

# =============================================================================
# REDIS
# =============================================================================
GRIMOIRE_REDIS__HOST=localhost
GRIMOIRE_REDIS__PORT=6379
GRIMOIRE_REDIS__DB_CACHE=2
GRIMOIRE_REDIS__DB_RATE_LIMIT=3
GRIMOIRE_REDIS__PASSWORD=

# =============================================================================
# VECTOR STORE — separate collection from the general-domain instance
# =============================================================================
GRIMOIRE_VECTOR_STORE__TYPE=chromadb
GRIMOIRE_VECTOR_STORE__CHROMADB__PATH=./chroma_db_security
GRIMOIRE_VECTOR_STORE__CHROMADB__COLLECTION_NAME=security_grimoire

# =============================================================================
# LLM — cloud Ollama / OpenAI-compatible endpoint
# The security compose overlay does NOT ship a local Ollama container; point
# this at a remote endpoint or a system-level Ollama daemon on the host.
# =============================================================================
GRIMOIRE_LLM__URL=https://api.your-ollama-host.example
GRIMOIRE_LLM__MODEL=llama3.1:8b
GRIMOIRE_LLM__TEMPERATURE=0.3
GRIMOIRE_LLM__MAX_TOKENS=2048
GRIMOIRE_LLM__TIMEOUT=300
# Optional fallback
# GRIMOIRE_LLM__FALLBACK_URL=
# GRIMOIRE_LLM__FALLBACK_MODEL=

# =============================================================================
# EMBEDDINGS — HF Inference API works well from a Hetzner box without a GPU.
# Switch to a local sentence-transformers model if you do have a GPU.
# =============================================================================
GRIMOIRE_EMBEDDINGS__MODEL=sentence-transformers/all-mpnet-base-v2
GRIMOIRE_EMBEDDINGS__FALLBACK_MODEL=sentence-transformers/all-MiniLM-L6-v2
GRIMOIRE_EMBEDDINGS__DEVICE=cpu
GRIMOIRE_EMBEDDINGS__BATCH_SIZE=16

# =============================================================================
# LOGGING
# =============================================================================
GRIMOIRE_LOGGING__LEVEL=INFO
GRIMOIRE_LOGGING__LOG_DIR=./logs
GRIMOIRE_LOGGING__ROTATION=1 week
GRIMOIRE_LOGGING__RETENTION=1 month
GRIMOIRE_LOGGING__STRUCTURED=true
GRIMOIRE_LOGGING__USE_JSON=true

# =============================================================================
# CELERY
# =============================================================================
GRIMOIRE_CELERY__BROKER_URL=redis://localhost:6379/0
GRIMOIRE_CELERY__RESULT_BACKEND=redis://localhost:6379/1
GRIMOIRE_CELERY__TASK_SERIALIZER=json
GRIMOIRE_CELERY__ACCEPT_CONTENT=["json"]
GRIMOIRE_CELERY__RESULT_SERIALIZER=json
GRIMOIRE_CELERY__TIMEZONE=UTC
GRIMOIRE_CELERY__ENABLE_UTC=true

# =============================================================================
# CHUNKING — security chunker dispatches per source type; these defaults
# apply to the prose fallback only.
# =============================================================================
GRIMOIRE_CHUNKING__DEFAULT_STRATEGY=recursive
GRIMOIRE_CHUNKING__CHUNK_SIZE=1000
GRIMOIRE_CHUNKING__CHUNK_OVERLAP=200

# =============================================================================
# PROCESSING
# =============================================================================
GRIMOIRE_PROCESSING__PARSE_PDF_OCR=false
GRIMOIRE_PROCESSING__PARSE_IMAGES=false
GRIMOIRE_PROCESSING__AUTO_TAG_THRESHOLD=0.7
GRIMOIRE_PROCESSING__DEDUP_STRATEGY=hash
GRIMOIRE_PROCESSING__CONCURRENCY=4

# =============================================================================
# QUERY / RAG
# =============================================================================
GRIMOIRE_QUERY__DEFAULT_TOP_K=10
GRIMOIRE_QUERY__RERANK_TOP_K=50
GRIMOIRE_QUERY__RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
GRIMOIRE_QUERY__HYBRID_ALPHA=0.7
GRIMOIRE_QUERY__ENABLE_CITATIONS=true

# =============================================================================
# CACHE
# =============================================================================
GRIMOIRE_CACHE__STORAGE=disk
GRIMOIRE_CACHE__PATH=./cache_security
GRIMOIRE_CACHE__EMBEDDING_TTL=604800
GRIMOIRE_CACHE__RESULT_TTL=86400

# =============================================================================
# API
# =============================================================================
GRIMOIRE_API__HOST=0.0.0.0
GRIMOIRE_API__PORT=8001
GRIMOIRE_API__RELOAD=false
GRIMOIRE_API__WORKERS=2
# CHANGE THIS — used for API key hashing. Use:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
GRIMOIRE_API__SECRET_KEY=CHANGE_ME_BEFORE_DEPLOY

# =============================================================================
# AUTH & RATE LIMITING
# =============================================================================
GRIMOIRE_AUTH__CORS_ORIGINS=["*"]
GRIMOIRE_AUTH__RATE_LIMITS={"agt":"600/minute","dvl":"120/minute","rdl":"30/minute"}

# =============================================================================
# WIKI — disabled by default in security deployments
# =============================================================================
GRIMOIRE_WIKI__COMPILE_ON_INGEST=false

# =============================================================================
# TOP-LEVEL
# =============================================================================
GRIMOIRE_DEBUG=false

# =============================================================================
# DOCKER-COMPOSE-ONLY VARS — read by the overlay, not by the Python app
# =============================================================================
CHROMADB_PORT=8002
# Directory on the host that the security ingestion agent reads from.
SECURITY_CORPUS_DIR=./security-corpus
